    "It is not recommended to export settings from one device and import them in another. Some settings will not work on other devices. Deep links, on the other hand, can be imported on any device." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "It is not recommended to export settings from one device and import them in another. Some settings will not work on other devices. Deep links, on the other hand, can be imported on any device."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "It is not recommended to export settings from one device and import them in another. Some settings will not work on other devices. Deep links, on the other hand, can be imported on any device."
          }
        },
